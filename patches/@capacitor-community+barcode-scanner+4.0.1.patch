+
+        guard let device = AVCaptureDevice.default(for: AVMediaType.video) else {
+            call.resolve()
+            return
+        }
+
+        do {
+            try device.lockForConfiguration()
+
+            let minZoom: CGFloat = 1.0
+            let maxZoom = min(device.activeFormat.videoMaxZoomFactor, CGFloat(5.0))
+            let zoomFactor = min(max(CGFloat(1.0) + (CGFloat(zoom) * CGFloat(0.1)), minZoom), maxZoom)
+
+            device.videoZoomFactor = zoomFactor
+
+            device.unlockForConfiguration()
+        } catch {
+            print(error)
+        }
+
+        call.resolve()
+    }
